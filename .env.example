# Canonical env reference for docker-webtop-tribe.
# Copy to .env (never commit) and fill in what you need for your scenario.
# Not every var applies to every deployment — see the section headers.

# =============================================================================
# Build-time args (docker compose build or podman build --build-arg KEY=value)
# =============================================================================

# Extra Alpine packages baked into the image (space-separated).
# Example: "firefox-esr libreoffice remmina code-oss"
EXTRA_PACKAGES=

# Packages to remove from the default set (space-separated).
# Example: "mousepad ristretto"
REMOVE_PACKAGES=

# Include chromium in the build. Set to "false" for a locked-down image.
INCLUDE_CHROMIUM=true

# Bake in the Nous Research Hermes Agent (self-improving AI CLI).
# Adds ~300-500MB. First build is slow (pydantic-core compiles from source).
INSTALL_HERMES=true

# Git ref for hermes-agent. Pin to a tag for reproducible builds.
HERMES_REF=v2026.4.13

# =============================================================================
# Runtime env (docker compose up or podman/docker run -e KEY=value)
# =============================================================================

# LSIO standard user/group mapping. Inside the container, abc is remapped
# to these. Under rootless podman, leave PUID/PGID at 1000 and run with
# the DEFAULT userns — no --userns=keep-id (see examples/podman-run.sh).
PUID=1000
PGID=1000
UMASK=027
TZ=Etc/UTC

# Desktop title shown in the browser tab.
TITLE=Tribe Workspace

# Optional Selkies built-in basic auth (layered inside any outer auth).
# Leave unset to disable.
CUSTOM_USER=
PASSWORD=

# --- enterprise init hook (root/etc/s6-overlay/.../init-enterprise) ---
# Runs after LSIO's init-adduser. All optional.
ENTERPRISE_FULLNAME=
ENTERPRISE_SHELL=/bin/bash
# Space-separated "name:gid" pairs. Groups are created and abc joined.
# Example: "devs:1001 docker:999"
ENTERPRISE_GROUPS=
# Grant abc passwordless sudo. Installs sudo on first run if missing.
# SECURITY: keep false unless you trust the user completely.
ENTERPRISE_SUDO=false

# --- security hardening ---
# HARDEN_DESKTOP=true disables xdg-open, terminal emulators, and sudo.
HARDEN_DESKTOP=true
# DISABLE_SUDO=true removes sudo execute permissions.
DISABLE_SUDO=true
# DISABLE_OPEN_TOOLS=true removes xdg-open / exo-open.
DISABLE_OPEN_TOOLS=true

# =============================================================================
# Auth Gate (auth-gate/server.ts)
# =============================================================================

# https://dashboard.clerk.com -> your app -> API Keys
# Dev keys (pk_test_... / sk_test_...) work fine on localhost.
# Use production keys (pk_live_... / sk_live_...) on a real VPS.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx

# Comma-separated allow-lists. Leave both empty to allow any signed-in
# Clerk user. Set one or both to narrow further.
ALLOWED_EMAILS=
ALLOWED_USER_IDS=

# Force HTTPS redirect. Set to true in production, false for local dev.
FORCE_HTTPS=false

# =============================================================================
# PTY Server (terminal service inside webtop)
# =============================================================================

# Internal port for the PTY server HTTP API (Hermes exec + resize).
PTY_PORT=8081
# Default working directory for new shell sessions.
PTY_CWD=/config/workspace
# Shell binary to spawn inside the PTY.
PTY_SHELL=/bin/bash

# =============================================================================
# Local dev overrides (cd auth-gate && bun run dev)
# =============================================================================

# Where the gate proxies authenticated traffic. In compose this is the
# service name; for local dev point it at a running webtop.
UPSTREAM=http://localhost:3001
PORT=8080
PUBLIC_URL=http://localhost:8080

# =============================================================================
# VPS deploy (examples/deploy/compose.yml)
# =============================================================================

# Public hostname — DNS A/AAAA must point at the VPS before first start.
DOMAIN=webtop.example.com
LETSENCRYPT_EMAIL=you@example.com
