#!/command/with-contenv bash
# Enterprise user/group customization.
# Runs after LSIO's init-adduser has remapped abc to PUID/PGID.
# Controlled entirely by env vars so one image serves many tenants.
#
#   ENTERPRISE_GROUPS   space-separated "name:gid" pairs to create and add abc to
#                       e.g. "devs:1001 docker:999"
#   ENTERPRISE_FULLNAME GECOS field for the abc user, e.g. "Corp User"
#   ENTERPRISE_SUDO     "true" to grant passwordless sudo to abc
#   ENTERPRISE_SHELL    login shell for abc, e.g. "/bin/bash"

set -e

if [ -n "${ENTERPRISE_FULLNAME}" ]; then
  usermod -c "${ENTERPRISE_FULLNAME}" abc 2>/dev/null || true
fi

if [ -n "${ENTERPRISE_SHELL}" ] && [ -x "${ENTERPRISE_SHELL}" ]; then
  usermod -s "${ENTERPRISE_SHELL}" abc 2>/dev/null || true
fi

if [ -n "${ENTERPRISE_GROUPS}" ]; then
  for entry in ${ENTERPRISE_GROUPS}; do
    name="${entry%%:*}"
    gid="${entry##*:}"
    if [ -n "${name}" ] && [ -n "${gid}" ] && [ "${name}" != "${gid}" ]; then
      getent group "${name}" >/dev/null 2>&1 || addgroup -g "${gid}" "${name}" 2>/dev/null || true
      adduser abc "${name}" 2>/dev/null || true
    fi
  done
fi

if [ "${ENTERPRISE_SUDO}" = "true" ]; then
  if ! command -v sudo >/dev/null 2>&1; then
    apk add --no-cache sudo >/dev/null 2>&1 || true
  fi
  if command -v sudo >/dev/null 2>&1; then
    echo 'abc ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/abc
    chmod 0440 /etc/sudoers.d/abc
  fi
fi

exit 0
