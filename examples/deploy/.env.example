# Copy to .env on the VPS and fill in every value. Never commit .env.

# Public hostname — DNS A/AAAA must already point at the VPS.
DOMAIN=webtop.example.com
LETSENCRYPT_EMAIL=you@example.com
TZ=Etc/UTC

# ---- Clerk ----
# https://dashboard.clerk.com -> your app -> API Keys
# Use the PRODUCTION instance for a real deployment; the dev instance
# only works from localhost.
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx

# ---- Access control ----
# Leave both empty to allow any signed-in Clerk user (fine if your
# Clerk instance itself is restricted — e.g. a private organization).
# Set either or both to narrow further. Comma-separated, no spaces.
ALLOWED_EMAILS=you@example.com,teammate@example.com
ALLOWED_USER_IDS=
